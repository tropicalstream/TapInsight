<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:foreground="#1A000000">

    <LinearLayout
        android:id="@+id/hudContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@color/bg_panel_soft"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/hudTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hud_time"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/hudBatteryContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/hudBatteryIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Battery status"
                    android:src="@drawable/ic_battery_status"
                    android:tint="#FFFFFFFF" />

                <TextView
                    android:id="@+id/hudBatteryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="--%"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Connection status (green dot + G) below battery row -->
        <LinearLayout
            android:id="@+id/hudConnectionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/hudConnectionDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_connection_dot" />

            <TextView
                android:id="@+id/hudConnectionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="NET"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hudCalendarCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_hud_card"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/hudCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/hud_calendar"
                android:textColor="#FF00E5FF"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hudTasksCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_hud_card"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/hudTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF00E676"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hudNewsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_hud_card"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/hudNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFB14A"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:translationX="70dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="40dp"
        android:paddingBottom="130dp"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hudContainer" />

    <TextView
        android:id="@+id/chatStreamIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="22dp"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="..."
        android:textColor="#00FFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/chatRecycler"
        app:layout_constraintTop_toTopOf="@id/chatRecycler" />

    <FrameLayout
        android:id="@+id/readerOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/readerBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="6dp"
            android:background="@drawable/bg_reader_border" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/readerScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingHorizontal="18dp"
            android:paddingTop="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/readerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="4dp"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp" />
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    <com.rayneo.visionclaw.ui.VoiceOscilloscopeView
        android:id="@+id/chatInlineOscilloscope"
        android:layout_width="0dp"
        android:layout_height="132dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/chatRecycler"
        app:layout_constraintBottom_toBottomOf="@id/chatRecycler"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/coreEyeContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_core_eye_mask"
        android:clipToOutline="true"
        android:outlineProvider="background"
        app:layout_constraintBottom_toBottomOf="@id/chatInlineOscilloscope"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/chatInlineOscilloscope">

        <TextureView
            android:id="@+id/coreEyePreviewTexture"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/coreEyeRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_core_eye_ring"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/coreEyeIdleIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:alpha="0.82"
            android:contentDescription="Core Eye idle"
            android:src="@drawable/ic_camera_status"
            android:tint="#FFFFFFFF" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
